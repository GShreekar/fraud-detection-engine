APP_ENV=development

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Neo4j connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Velocity checks — sliding window duration (seconds) and max transactions before flagging
VELOCITY_WINDOW_SECONDS=60
VELOCITY_MAX_TRANSACTIONS=10
VELOCITY_MAX_TRANSACTIONS_IP=5

# RulesService — USD amount above which the high-amount rule triggers
HIGH_AMOUNT_THRESHOLD=1000.0
# RulesService — JSON list of ISO 3166-1 alpha-2 country codes treated as high-risk
HIGH_RISK_COUNTRIES=["NG","GH","KP","IR","SY","YE","SO","MM","CN","KE"]

# GraphService — minimum distinct users sharing a device/IP before scoring begins
GRAPH_SHARED_DEVICE_THRESHOLD=2
GRAPH_IP_CLUSTER_THRESHOLD=3
# GraphService — enable/disable account takeover signal for first-seen device
GRAPH_ENABLE_NEW_DEVICE_FOR_USER=false

# FraudEngine score weights — must sum to 1.0
WEIGHT_RULES=0.50
WEIGHT_VELOCITY=0.25
WEIGHT_GRAPH=0.25
